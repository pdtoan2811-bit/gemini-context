const DeepResearchPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.deepResearch.animation");

  useEffect(() => {
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 4);
    }, 3000);
    return () => clearInterval(timer);
  }, []);

  return (
    <div className="flex flex-1 w-full h-full min-h-[240px] rounded-2xl bg-card/60 backdrop-blur-lg p-4 relative border border-border/40 dark:border-[#4C8CE4]/10 transition-colors duration-500 overflow-hidden flex-col gap-3 shadow-sm">
      {/* Pseudo Search Bar */}
      <div className="flex items-center gap-2 px-3 py-2 bg-background rounded-xl border border-border/50 shadow-sm z-10 w-full shrink-0">
        <Search className="size-3.5 text-foreground" />
        <div className="text-[11px] font-medium text-foreground relative flex-1">
          <span className="opacity-0">{t("searchPlaceholder")}</span>
          <motion.div 
            initial={{ width: "0%" }} 
            animate={{ width: step >= 1 ? "100%" : "0%" }}
            className="absolute inset-0 overflow-hidden break-normal whitespace-nowrap"
          >
             {t("searchPlaceholder")}
          </motion.div>
          {step === 1 && (
             <motion.span animate={{ opacity: [1, 0, 1] }} transition={{ repeat: Infinity, duration: 0.5 }} className="w-0.5 h-3 bg-foreground inline-block absolute ml-1 top-0.5" />
          )}
        </div>
      </div>

      {/* Internal Content Area */}
      <div className="flex-1 relative w-full h-[160px] overflow-hidden">
        <AnimatePresence>
           {/* Scanning State */}
           {step === 1 && (
              <motion.div
                key="scanning"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0, position: "absolute", top: 0, left: 0 }}
                className="w-full h-full flex flex-col gap-3 absolute top-0 left-0 pt-2"
              >
                 <div className="flex justify-between items-center px-1">
                   <div className="text-[9px] font-bold uppercase tracking-widest text-foreground flex items-center gap-1.5">
                     <div className="size-1.5 rounded-full bg-foreground animate-ping" /> {t("scanning")}
                   </div>
                   <span className="text-[9px] text-muted-foreground">2/15</span>
                 </div>
                 {/* Scanning skeleton lines */}
                 <div className="space-y-2 w-full">
                    <div className="h-1.5 w-full bg-foreground/20 rounded-full overflow-hidden relative">
                       <motion.div initial={{ x: "-100%" }} animate={{ x: "200%" }} transition={{ repeat: Infinity, duration: 1.5, ease: "linear" }} className="h-full w-1/3 bg-foreground" />
                    </div>
                    <div className="h-1.5 w-full bg-border rounded-full" />
                    <div className="h-1.5 w-3/4 bg-border rounded-full" />
                 </div>
              </motion.div>
           )}

           {/* Results State */}
           {step >= 2 && (
              <motion.div
                key="results"
                initial={{ opacity: 0, x: 20 }}
                animate={{ opacity: 1, x: 0 }}
                exit={{ opacity: 0, position: "absolute", top: 0, left: 0 }}
                className="w-full h-full flex flex-col gap-2 pt-2 absolute top-0 left-0"
              >
                 {[t("result1"), t("result2")].map((name, i) => (
                    <motion.div 
                      key={name}
                      initial={{ opacity: 0, y: 10 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: i * 0.15 }}
                      className="bg-card/80 border border-border/50 rounded-xl p-2 flex items-center justify-between shadow-sm shrink-0"
                    >
                       <div className="flex flex-col">
                         <span className="text-[11px] font-bold text-foreground">{name}</span>
                         <span className="text-[9px] text-foreground font-semibold">{t("commissionRecurring")}</span>
                       </div>
                       <Button size="icon" variant="ghost" className="size-6 h-6 w-6 shrink-0 bg-foreground/5 hover:bg-foreground/10">
                          <Plus className="size-3 text-foreground" />
                       </Button>
                    </motion.div>
                 ))}
                 <motion.div 
                   initial={{ scale: 0.9, opacity: 0 }}
                   animate={{ scale: 1, opacity: 1 }}
                   transition={{ delay: 0.3 }}
                   className="w-full mt-1 bg-[#91D06C]/10 border border-[#91D06C]/20 py-1.5 rounded-lg flex justify-center items-center gap-1.5 shrink-0"
                 >
                    <ShieldCheck className="size-3 text-[#91D06C]" />
                    <span className="text-[10px] font-bold text-[#91D06C] uppercase tracking-widest">{t("verified")}</span>
                 </motion.div>
              </motion.div>
           )}
        </AnimatePresence>
      </div>
    </div>
  );
};

// ----------------------------------------------------------------------
// 3. Analytics Preview (Sequential View)
// ----------------------------------------------------------------------

function AnimatedCounter({ value, prefix = "", suffix = "" }: { value: number, prefix?: string, suffix?: string }) {
  const motionVal = useMotionValue(0);
  const springVal = useSpring(motionVal, { bounce: 0, duration: 1500 });
  const [displayValue, setDisplayValue] = useState("0");

  useEffect(() => {
    motionVal.set(value);
  }, [value, motionVal]);

  useEffect(() => {
    return springVal.on("change", (latest) => {
      setDisplayValue(Math.floor(latest).toLocaleString());
    });
  }, [springVal]);

  return <span>{prefix}{displayValue}{suffix}</span>;
}

const AnalyticsPreview = () => {
