};

// ----------------------------------------------------------------------
// 4. Project Management Preview (Live Mockup: Connect Ads & Input Refs)
// ----------------------------------------------------------------------
const ProjectManagementPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.projects.animation");

  useEffect(() => {
    // 0: Init & Focus Left (Nodes sliding in)
    // 1: Connect lines draw out
    // 2: Pan to Right Hub
    // 3: Aggregate Costs roll up
    // 4: Zoom Right Hub & Ref Input pops up
    // 5: Typing Ref
    // 6: Pull back to full landscape view
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 7); 
    }, 2200); 
    return () => clearInterval(timer);
  }, []);

  // Aggregated Cost logic
  const aggregatedCost = step >= 3 ? 4100 : 0;

  // Camera settings
  const getCameraState = (s: number) => {
    switch(s) {
      case 0:
      case 1:
        return { x: 180, y: 0, scale: 1.15 }; // Focused Left
      case 2:
      case 3:
        return { x: -180, y: 0, scale: 1.05 }; // Focused Right
      case 4:
      case 5:
        return { x: -180, y: -20, scale: 1.1 }; // Slight push in for input
      case 6:
        // Full pull-back to show perfect diagram
        return { x: -20, y: 0, scale: 0.7 }; 
      default:
        return { x: -20, y: 0, scale: 0.7 };
    }
  };

  const camera = getCameraState(step);

  return (
    <div className="flex flex-1 w-full h-[220px] lg:h-[280px] rounded-2xl bg-card/60 backdrop-blur-lg border border-border/40 relative overflow-hidden items-center justify-center shadow-sm font-sans text-foreground">
        
        {/* Floating Action Overlay indicating manual operation */}
        <AnimatePresence>
           {step === 5 && (
              <motion.div 
                 initial={{ opacity: 0, scale: 0.5, y: -10 }} animate={{ opacity: 1, scale: 1, y: 0 }} exit={{ opacity: 0, scale: 0.8 }}
                 className="absolute top-4 bg-foreground text-background px-4 py-2 rounded-full text-[10px] font-bold z-30 shadow-2xl flex items-center gap-2 uppercase tracking-widest border border-foreground/20"
              >
                 <CheckCircle2 className="size-3.5" />
                 {t("manualSyncOverlay", { fallback: "Manual Sync" })}
              </motion.div>
           )}
        </AnimatePresence>

        {/* The Cinematic World Canvas (Fixed Absolute Size to prevent any stretching!) */}
        <motion.div 
           animate={{ x: camera.x, y: camera.y, scale: camera.scale }}
           transition={{ duration: 1.2, ease: [0.25, 0.1, 0.25, 1] }}
           className="w-[660px] h-[300px] absolute flex items-center justify-center transform-origin-center"
        >
            {/* SVG Data Pipeline Connections (Fixed Coordinates) */}
            <svg className="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 660 300">
               <defs>
                 <linearGradient id="gradientFlowProject" x1="0" y1="0" x2="1" y2="0">
                   <stop offset="0%" stopColor="currentColor" stopOpacity="0.05" />
                   <stop offset="50%" stopColor="currentColor" stopOpacity="0.8" />
                   <stop offset="100%" stopColor="currentColor" stopOpacity="1" />
                 </linearGradient>
                 <filter id="glowProject">
                    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                    <feMerge>
                        <feMergeNode in="coloredBlur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                 </filter>
               </defs>

               {/* 
                 Left Nodes edge: X = 180
                 Right Hub Left edge: X = 420
                 Y targets: Top=90, Mid=150, Bot=210
               */}

               {/* Base Dashed Paths from X=210 (Node edge) to X=420 (Hub Edge) */}
               <path d="M 210 65 C 315 65, 315 150, 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />
               <path d="M 210 150 L 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />
               <path d="M 210 235 C 315 235, 315 150, 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />

               {/* Animated Solid Paths */}
               <motion.path 
                  d="M 210 65 C 315 65, 315 150, 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut" }}
               />
               <motion.path 
                  d="M 210 150 L 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut", delay: 0.15 }}
               />
               <motion.path 
                  d="M 210 235 C 315 235, 315 150, 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut", delay: 0.3 }}
               />

               {/* Data Pulses moving along exact paths */}
               {(step >= 2 && step <= 5) && (
                 <>
                   <motion.circle r="3.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2s" repeatCount="indefinite" path="M 210 65 C 315 65, 315 150, 420 150" />
                   </motion.circle>
                   <motion.circle r="4" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="1.7s" repeatCount="indefinite" begin="0.3s" path="M 210 150 L 420 150" />
                   </motion.circle>
                   <motion.circle r="3.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2.1s" repeatCount="indefinite" begin="0.6s" path="M 210 235 C 315 235, 315 150, 420 150" />
                   </motion.circle>
                   {/* Second wave */}
                   <motion.circle r="2.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2s" repeatCount="indefinite" begin="1s" path="M 210 65 C 315 65, 315 150, 420 150" />
                   </motion.circle>
                   <motion.circle r="3" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="1.7s" repeatCount="indefinite" begin="1.2s" path="M 210 150 L 420 150" />
                   </motion.circle>
                 </>
               )}
            </svg>

            {/* left column Nodes (Hierarchical Data Path) */}
            {/* Right Edge must remain at X = 210. Width 180 -> Left = 30 */}
            <div className="absolute left-[30px] top-[27.5px] flex flex-col gap-2.5 z-10 w-[180px]">
                
                {/* Node 1 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">farm1@gmail.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 341-992-120</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Scale_Max_US</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Search_Exact</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: RSVP_Alpha</span></div>
                       
                       {/* Connection nub */}
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>

                {/* Node 2 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }} transition={{ delay: 0.15 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">agency4@outlook.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 512-108-410</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Promo_Retarget</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Broad_Match</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: Sale_Offer</span></div>
                       
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>

                {/* Node 3 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }} transition={{ delay: 0.3 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">buy_vps2@yahoo.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 901-443-551</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Brand_Defense</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Phrase_KW</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: Core_Value</span></div>
                       
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>
            </div>

            {/* Project Hub Stack (Background Cards to imply multiple projects) */}
            <div className="absolute left-[432px] top-[40px] w-[230px] h-[200px] bg-card/40 border border-border/40 rounded-2xl z-10 scale-[0.96] shadow-sm backdrop-blur-[2px]" />
            <div className="absolute left-[442px] top-[30px] w-[230px] h-[200px] bg-card/20 border border-border/20 rounded-2xl z-0 scale-[0.92] backdrop-blur-[4px]" />

            {/* Right Dashboard Node (Fixed absolute position) */}
            {/* Center X = 535 (Width 230 so Edges 420 to 650) */}
            <div className="absolute left-[420px] top-[50px] w-[230px] h-[200px] bg-card/95 backdrop-blur-md border border-border/80 rounded-2xl p-5 flex flex-col justify-between shadow-xl z-20 overflow-hidden shrink-0">
                
                {/* Connection nub receiver */}
                <div className="absolute left-[-4px] top-[100px] -translate-y-1/2 size-2 rounded-full bg-border" />
                {/* Subtle gradient flash when data arrives */}
                <motion.div 
                    animate={{ opacity: (step >= 2 && step <= 4) ? [0, 0.3, 0] : 0 }} 
                    transition={{ repeat: Infinity, duration: 2 }} 
                    className="absolute inset-0 bg-gradient-to-r from-foreground/10 to-transparent pointer-events-none" 
                />

                <div className="flex flex-col gap-1 relative z-10 p-0.5">
                    <div className="flex items-center gap-2 text-muted-foreground mb-1.5">
                        <FolderKanban className="size-4" />
                        <span className="text-[10px] font-black uppercase tracking-widest truncate">{t("project")}</span>
                    </div>
                    <span className="text-[11px] font-bold text-muted-foreground uppercase pt-1">{t("totalSpend")}</span>
                    <span className="text-3xl font-black text-foreground tabular-nums tracking-tight leading-none mb-1">
                        $<AnimatedCounter value={aggregatedCost} />
                    </span>
                </div>

                <div className="w-full relative min-h-[75px] mt-auto flex items-end">
                    <AnimatePresence mode="popLayout">
                        {step <= 3 && (
                            <motion.div 
                                key="connecting"
                                initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0, y: 15 }}
                                className="w-full flex justify-center items-center h-[75px] text-[11px] text-muted-foreground font-medium italic"
                            >
                                {step === 0 ? t("connectAdsTitle") : (step <= 2 ? t("syncingAccounts") : t("accountsConnected"))}
                            </motion.div>
                        )}
                        
                        {(step === 4 || step === 5) && (
                            <motion.div 
                                key="input"
                                initial={{ opacity: 0, y: 30 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, scale: 0.95 }}
                                className="w-full bg-background border border-border/80 rounded-xl p-3 shadow-inner h-[75px] flex flex-col justify-center"
                            >
                                <span className="text-[10px] font-bold text-foreground block mb-2">{t("inputRefTitle")}</span>
                                <div className="h-8 w-full bg-muted/40 rounded-lg flex items-center px-2.5 border border-border/50 text-[12px] font-semibold text-foreground relative">
                                    <span className="text-muted-foreground mr-2">{t("refValueLabel", { fallback: "Ref:" })}</span>
                                    <span className="opacity-0">452</span>
                                    <div className="absolute left-[40px] overflow-hidden">
                                        <motion.div 
                                            initial={{ width: 0 }} animate={{ width: step === 5 ? "auto" : 0 }}
                                            className="tabular-nums font-bold"
                                        >
                                            452
                                        </motion.div>
                                    </div>
                                    {step === 4 && <motion.div animate={{ opacity:[0,1,0] }} transition={{ repeat: Infinity }} className="h-4 w-[2px] bg-foreground ml-1" />}
                                </div>
                            </motion.div>
                        )}

                        {step >= 6 && (
                            <motion.div 
                                key="results"
                                initial={{ opacity: 0, y: 30, scale: 0.9 }} animate={{ opacity: 1, y: 0, scale: 1 }}
                                className="w-full flex items-end gap-2.5 h-[75px]"
                            >
                                <div className="flex-1 bg-[#91D06C]/10 border border-[#91D06C]/30 rounded-xl p-2.5 flex flex-col justify-center h-full relative overflow-hidden text-center shadow-sm">
                                    <span className="text-[9px] font-bold text-[#91D06C] uppercase tracking-wider mb-1">{t("trueCpa")}</span>
                                    <span className="text-[18px] font-black text-[#91D06C] tracking-tight leading-none">$9.07</span>
                                </div>
                                <div className="w-[70px] bg-background border border-border/60 rounded-xl p-2.5 flex flex-col justify-center h-full text-center shadow-sm">
                                    <span className="text-[9px] font-bold text-muted-foreground uppercase tracking-wider mb-1">{t("roi")}</span>
                                    <span className="text-[14px] font-black text-foreground tracking-tight leading-none">312%</span>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>
                </div>
            </div>

        </motion.div>
    </div>
  );
};
===
"use client";

import { motion, AnimatePresence, useMotionValue, useSpring } from "framer-motion";
import { useTranslations } from "next-intl";
import { useEffect, useState } from "react";
import { BentoGrid, BentoGridItem } from "@/components/BentoGrid";
import { Button } from "@/components/ui/button";
import { 
  MessageSquare, 
  Search, 
  BarChart3, 
  FolderKanban,
  ShieldCheck,
  Sparkles,
  ArrowRight,
  CheckCircle2,
  Plus,
  Mail,
  Briefcase,
  Folder,
  Layers,
  FileText
} from "lucide-react";

export function LandingFeatures() {
  const t = useTranslations("landing.features");

  const items = [
    {
      title: t("aiAgent.title"),
      description: t("aiAgent.description"),
      header: <AIAgentPreview />,
      icon: <MessageSquare className="size-4 text-[#4C8CE4]" />,
      className: "md:col-span-2 md:row-span-2",
    },
    {
      title: t("deepResearch.title"),
      description: t("deepResearch.description"),
      header: <DeepResearchPreview />,
      icon: <Search className="size-4 text-[#4C8CE4]" />,
      className: "md:col-span-1 md:row-span-1",
    },
    {
      title: t("analytics.title"),
      description: t("analytics.description"),
      header: <AnalyticsPreview />,
      icon: <BarChart3 className="size-4 text-[#4C8CE4]" />,
      className: "md:col-span-1 md:row-span-1",
    },
    {
      title: t("projects.title"),
      description: t("projects.description"),
      header: <ProjectManagementPreview />,
      icon: <FolderKanban className="size-4 text-[#4C8CE4]" />,
      className: "md:col-span-3 md:row-span-1",
    },
  ];

  return (
    <section id="features" className="py-20 px-4 bg-background relative overflow-hidden">
      {/* Premium Spotlight Effect from Hero */}
      <div className="pointer-events-none absolute inset-0 z-0">
        <div 
          className="absolute inset-0 opacity-10 dark:opacity-20"
          style={{ background: `radial-gradient(circle at 50% 10%, var(--primary), transparent 60%)` }}
        />
        <div 
          className="absolute inset-0 opacity-[0.05] dark:opacity-10"
          style={{ background: `radial-gradient(circle at 50% 50%, var(--primary), transparent 100%)`, filter: "blur(100px)" }}
        />
      </div>

      <div className="max-w-7xl mx-auto space-y-12 relative z-10">
        <div className="text-center space-y-4">
          <motion.h2 
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5 }}
            className="text-3xl md:text-5xl font-bold tracking-tight text-foreground"
          >
            {t("sectionTitle")}
          </motion.h2>
          <motion.p 
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.5, delay: 0.1 }}
            className="text-muted-foreground text-lg max-w-2xl mx-auto"
          >
            {t("sectionSubtitle")}
          </motion.p>
        </div>
        
        <BentoGrid>
          {items.map((item, i) => (
            <BentoGridItem
              key={i}
              title={item.title}
              description={item.description}
              header={item.header}
              icon={item.icon}
              className={item.className}
            />
          ))}
        </BentoGrid>
      </div>
    </section>
  );
}

// ----------------------------------------------------------------------
// 1. AI Agent Preview (Full Chat Interface Mockup)
// ----------------------------------------------------------------------
const AIAgentPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.aiAgent.animation");

  useEffect(() => {
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 7);
    }, 3200);
    return () => clearInterval(timer);
  }, []);

  return (
    <div className="flex flex-col flex-1 w-full h-[520px] lg:h-[620px] rounded-2xl bg-card/60 backdrop-blur-lg overflow-hidden relative border border-border/40 dark:border-[#4C8CE4]/10 transition-colors duration-500 shadow-sm">
      {/* Fake Header */}
      <div className="h-14 w-full border-b border-border/60 bg-background/80 backdrop-blur-md flex items-center px-4 justify-between z-10 relative shrink-0">
        <div className="flex items-center gap-2.5">
          <div className="relative">
            <div className="size-7 bg-[#4C8CE4]/10 rounded-xl flex items-center justify-center shadow-sm border border-[#4C8CE4]/20">
              <Sparkles className="size-4 text-[#4C8CE4]" />
            </div>
            <div className="absolute -bottom-0.5 -right-0.5 size-3 bg-[#91D06C] border-[2px] border-background rounded-full shadow-sm" />
          </div>
          <span className="text-sm highlight-gradient">Adecos AI</span>
        </div>
      </div>

      {/* Chat Body */}
      <div className="flex-1 p-4 md:p-5 flex flex-col gap-5 relative z-10 justify-start overflow-hidden w-full">
        {/* User Message */}
        <AnimatePresence>
          {step >= 1 && (
            <motion.div
              initial={{ opacity: 0, y: 10, scale: 0.95 }}
              animate={{ opacity: 1, y: 0, scale: 1 }}
              className="self-end bg-foreground text-background text-[13px] font-medium px-4 py-3 rounded-2xl rounded-tr-md max-w-[85%] shadow-sm shrink-0 leading-relaxed"
            >
              {t("userPrompt")}
            </motion.div>
          )}
        </AnimatePresence>

        {/* AI Typing / Response container (Fixed bounds to prevent layout shifts) */}
        <div className="relative w-full flex-1 min-h-[360px]">
          <AnimatePresence>
            {/* Typing Indicator */}
            {step === 2 && (
              <motion.div
                key="typing"
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, scale: 0.95 }}
                className="absolute top-0 left-0 flex gap-2.5 items-end max-w-[85%]"
              >
                <div className="size-7 rounded-xl bg-[#4C8CE4]/10 border border-[#4C8CE4]/20 flex items-center justify-center shrink-0 shadow-sm">
                  <Sparkles className="size-4 text-primary animate-pulse" />
                </div>
                <div className="bg-card border border-border/60 px-4 py-3 rounded-2xl rounded-tl-md shadow-sm flex items-center gap-1.5 h-10">
                  {[0, 0.2, 0.4].map((d) => (
                    <motion.div key={d} animate={{ y: [0, -4, 0] }} transition={{ repeat: Infinity, duration: 0.6, delay: d }} className="size-2 bg-foreground/40 rounded-full" />
                  ))}
                </div>
              </motion.div>
            )}

            {/* AI Response Block */}
            {step >= 3 && (
              <motion.div
                 key="response"
                 initial={{ opacity: 0, y: 10 }}
                 animate={{ opacity: 1, y: 0 }}
                 className="absolute top-0 left-0 flex gap-2.5 max-w-[98%] w-full"
              >
                 <div className="size-7 rounded-xl bg-[#4C8CE4]/10 border border-[#4C8CE4]/20 flex items-center justify-center shrink-0 mt-0.5 shadow-sm">
                   <Sparkles className="size-4 text-[#4C8CE4]" />
                 </div>
                 
                 <div className="flex flex-col gap-3 w-full">
                    {/* Chat Bubble Component */}
                    <div className="bg-card border border-border/60 p-4 rounded-2xl rounded-tl-md shadow-md shadow-black/5 dark:shadow-none flex flex-col gap-4">
                       <p className="text-[12px] text-foreground font-medium leading-relaxed">
                         {t("responseIntro")}
                       </p>

                       {/* Taller Chart Component */}
                       <AnimatePresence>
                          {step >= 4 && (
                            <motion.div 
                              initial={{ opacity: 0, height: 0 }}
                              animate={{ opacity: 1, height: "auto" }}
                              className="bg-background border border-border/60 rounded-xl p-3 flex flex-col gap-3 overflow-hidden shadow-inner"
                            >
                               <div className="flex justify-between items-center px-1">
                                  <span className="text-[10px] font-black uppercase tracking-widest text-muted-foreground">{t("chartTitle")}</span>
                                  <div className="flex gap-2">
                                    <div className="flex items-center gap-1"><div className="size-2 rounded-sm bg-[#4C8CE4]/80" /><span className="text-[9px] text-muted-foreground font-bold">CTR</span></div>
                                    <div className="flex items-center gap-1"><div className="size-2 rounded-sm bg-[#91D06C]" /><span className="text-[9px] text-muted-foreground font-bold">CVR</span></div>
                                  </div>
                               </div>
                               <div className="flex items-end gap-2 w-full h-[80px] pt-2 px-1 relative">
                                  {/* Grid lines */}
                                  <div className="absolute inset-x-1 bottom-0 border-b border-dashed border-border/60" />
                                  <div className="absolute inset-x-1 top-1/2 border-b border-dashed border-border/60" />
                                  <div className="absolute inset-x-1 top-0 border-b border-dashed border-border/60" />
                                  
                                  {/* Bars */}
                                  {[
                                    {ctr: 20, cvr: 15}, {ctr: 35, cvr: 30}, {ctr: 30, cvr: 25}, 
                                    {ctr: 55, cvr: 45}, {ctr: 50, cvr: 40}, {ctr: 80, cvr: 70}, {ctr: 95, cvr: 85}
                                  ].map((d, i) => (
                                     <div key={i} className="flex-1 flex justify-center items-end gap-0.5 h-full relative z-10 group">
                                         <motion.div
                                          initial={{ height: 0 }}
                                          animate={{ height: `${d.ctr}%` }}
                                          transition={{ type: "spring", delay: i * 0.05 + 0.2, bounce: 0.3 }}
                                          className="w-1/2 bg-[#4C8CE4]/80 rounded-t-[2px] opacity-80 group-hover:opacity-100 transition-opacity"
                                        />
                                        <motion.div
                                          initial={{ height: 0 }}
                                          animate={{ height: `${d.cvr}%` }}
                                          transition={{ type: "spring", delay: i * 0.05 + 0.3, bounce: 0.3 }}
                                          className="w-1/2 bg-[#91D06C] rounded-t-[2px] opacity-80 group-hover:opacity-100 transition-opacity"
                                        />
                                     </div>
                                  ))}
                               </div>
                            </motion.div>
                          )}
                       </AnimatePresence>
                    </div>

                    {/* Distinct Action Plan Component (Widget UI outside the bubble) */}
                    <AnimatePresence>
                       {step >= 5 && (
                          <motion.div 
                            initial={{ opacity: 0, y: 10, scale: 0.98 }}
                            animate={{ opacity: 1, y: 0, scale: 1 }}
                            className="bg-card border border-border rounded-2xl p-4 flex flex-col gap-3 shadow-sm border-l-4 border-l-foreground"
                          >
                             <div className="flex justify-between items-center">
                                <span className="text-[11px] font-black uppercase tracking-wider text-foreground flex items-center gap-1.5">
                                   <ShieldCheck className="size-3.5 text-[#4C8CE4]" />
                                   {t("actionPlanTitle")}
                                </span>
                                <span className="text-[10px] font-bold bg-foreground text-background px-2 py-0.5 rounded border border-border">
                                   {t("actionPlanImpact")}
                               </span>
                             </div>

                             <div className="flex flex-col gap-2 bg-background/50 rounded-xl p-3 border border-border">
                                <div className="flex items-start gap-2.5 group cursor-default">
                                   <div className={`mt-0.5 size-4 rounded-md border flex items-center justify-center shrink-0 transition-colors ${step >= 6 ? 'bg-[#4C8CE4] border-[#4C8CE4]' : 'bg-card border-border'}`}>
                                      {step >= 6 && <CheckCircle2 className="size-3 text-primary-foreground" />}
                                   </div>
                                   <span className={`text-[11px] font-medium leading-snug transition-colors ${step >= 6 ? 'text-muted-foreground line-through' : 'text-foreground'}`}>{t("todoTask1")}</span>
                                </div>
                                <div className="flex items-start gap-2.5 group cursor-default">
                                   <div className={`mt-0.5 size-4 rounded-md border flex items-center justify-center shrink-0 transition-colors ${step >= 6 ? 'bg-[#4C8CE4] border-[#4C8CE4]' : 'bg-card border-border'}`}>
                                      {step >= 6 && <CheckCircle2 className="size-3 text-primary-foreground" />}
                                   </div>
                                   <span className={`text-[11px] font-medium leading-snug transition-colors ${step >= 6 ? 'text-muted-foreground line-through' : 'text-foreground'}`}>{t("todoTask2")}</span>
                                </div>
                             </div>

                             {step >= 6 && (
                                <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} className="mt-1 w-full relative">
                                   <Button size="sm" className="w-full highlight-bg hover:opacity-90 h-9 rounded-lg text-xs transition-all hover:scale-[1.02]">
                                     {t("applyStrategy")} <ArrowRight className="size-3.5 ml-2" />
                                   </Button>
                                </motion.div>
                             )}
                          </motion.div>
                       )}
                    </AnimatePresence>
                 </div>

              </motion.div>
            )}
          </AnimatePresence>
        </div>
      </div>

      {/* Fake Input Area */}
      <div className="absolute bottom-5 left-5 right-5 h-12 bg-card/90 backdrop-blur-xl rounded-xl border border-border shadow-md dark:shadow-none flex items-center px-4 z-20 shrink-0">
        <span className="text-sm text-muted-foreground font-medium">{t("inputPlaceholder")}</span>
        <div className="ml-auto size-7 rounded-lg bg-[#4C8CE4]/10 border border-[#4C8CE4]/20 flex items-center justify-center shadow-sm">
          <ArrowRight className="size-3.5 text-[#4C8CE4]" />
        </div>
      </div>
    </div>
  );
};

// ----------------------------------------------------------------------
// 2. Deep Research Preview (Live Scanning Pipeline)
// ----------------------------------------------------------------------
const DeepResearchPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.deepResearch.animation");

  useEffect(() => {
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 4);
    }, 3000);
    return () => clearInterval(timer);
  }, []);

  return (
    <div className="flex flex-1 w-full h-full min-h-[240px] rounded-2xl bg-card/60 backdrop-blur-lg p-4 relative border border-border/40 dark:border-[#4C8CE4]/10 transition-colors duration-500 overflow-hidden flex-col gap-3 shadow-sm">
      {/* Pseudo Search Bar */}
      <div className="flex items-center gap-2 px-3 py-2 bg-background rounded-xl border border-border/50 shadow-sm z-10 w-full shrink-0">
        <Search className="size-3.5 text-foreground" />
        <div className="text-[11px] font-medium text-foreground relative flex-1">
          <span className="opacity-0">{t("searchPlaceholder")}</span>
          <motion.div 
            initial={{ width: "0%" }} 
            animate={{ width: step >= 1 ? "100%" : "0%" }}
            className="absolute inset-0 overflow-hidden break-normal whitespace-nowrap"
          >
             {t("searchPlaceholder")}
          </motion.div>
          {step === 1 && (
             <motion.span animate={{ opacity: [1, 0, 1] }} transition={{ repeat: Infinity, duration: 0.5 }} className="w-0.5 h-3 bg-foreground inline-block absolute ml-1 top-0.5" />
          )}
        </div>
      </div>

      {/* Internal Content Area */}
      <div className="flex-1 relative w-full h-[160px] overflow-hidden">
        <AnimatePresence>
           {/* Scanning State */}
           {step === 1 && (
              <motion.div
                key="scanning"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0, position: "absolute", top: 0, left: 0 }}
                className="w-full h-full flex flex-col gap-3 absolute top-0 left-0 pt-2"
              >
                 <div className="flex justify-between items-center px-1">
                   <div className="text-[9px] font-bold uppercase tracking-widest text-foreground flex items-center gap-1.5">
                     <div className="size-1.5 rounded-full bg-foreground animate-ping" /> {t("scanning")}
                   </div>
                   <span className="text-[9px] text-muted-foreground">2/15</span>
                 </div>
                 {/* Scanning skeleton lines */}
                 <div className="space-y-2 w-full">
                    <div className="h-1.5 w-full bg-foreground/20 rounded-full overflow-hidden relative">
                       <motion.div initial={{ x: "-100%" }} animate={{ x: "200%" }} transition={{ repeat: Infinity, duration: 1.5, ease: "linear" }} className="h-full w-1/3 bg-foreground" />
                    </div>
                    <div className="h-1.5 w-full bg-border rounded-full" />
                    <div className="h-1.5 w-3/4 bg-border rounded-full" />
                 </div>
              </motion.div>
           )}

           {/* Results State */}
           {step >= 2 && (
              <motion.div
                key="results"
                initial={{ opacity: 0, x: 20 }}
                animate={{ opacity: 1, x: 0 }}
                exit={{ opacity: 0, position: "absolute", top: 0, left: 0 }}
                className="w-full h-full flex flex-col gap-2 pt-2 absolute top-0 left-0"
              >
                 {[t("result1"), t("result2")].map((name, i) => (
                    <motion.div 
                      key={name}
                      initial={{ opacity: 0, y: 10 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: i * 0.15 }}
                      className="bg-card/80 border border-border/50 rounded-xl p-2 flex items-center justify-between shadow-sm shrink-0"
                    >
                       <div className="flex flex-col">
                         <span className="text-[11px] font-bold text-foreground">{name}</span>
                         <span className="text-[9px] text-foreground font-semibold">{t("commissionRecurring")}</span>
                       </div>
                       <Button size="icon" variant="ghost" className="size-6 h-6 w-6 shrink-0 bg-foreground/5 hover:bg-foreground/10">
                          <Plus className="size-3 text-foreground" />
                       </Button>
                    </motion.div>
                 ))}
                 <motion.div 
                   initial={{ scale: 0.9, opacity: 0 }}
                   animate={{ scale: 1, opacity: 1 }}
                   transition={{ delay: 0.3 }}
                   className="w-full mt-1 bg-[#91D06C]/10 border border-[#91D06C]/20 py-1.5 rounded-lg flex justify-center items-center gap-1.5 shrink-0"
                 >
                    <ShieldCheck className="size-3 text-[#91D06C]" />
                    <span className="text-[10px] font-bold text-[#91D06C] uppercase tracking-widest">{t("verified")}</span>
                 </motion.div>
              </motion.div>
           )}
        </AnimatePresence>
      </div>
    </div>
  );
};

// ----------------------------------------------------------------------
// 3. Analytics Preview (Sequential View)
// ----------------------------------------------------------------------

function AnimatedCounter({ value, prefix = "", suffix = "" }: { value: number, prefix?: string, suffix?: string }) {
  const motionVal = useMotionValue(0);
  const springVal = useSpring(motionVal, { bounce: 0, duration: 1500 });
  const [displayValue, setDisplayValue] = useState("0");

  useEffect(() => {
    motionVal.set(value);
  }, [value, motionVal]);

  useEffect(() => {
    return springVal.on("change", (latest) => {
      setDisplayValue(Math.floor(latest).toLocaleString());
    });
  }, [springVal]);

  return <span>{prefix}{displayValue}{suffix}</span>;
}

const AnalyticsPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.analytics.animation");

  useEffect(() => {
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 2); // Sequences between 0 (KPIs) and 1 (Chart)
    }, 4500);
    return () => clearInterval(timer);
  }, []);

  return (
    <div className="flex flex-1 w-full h-full min-h-[220px] rounded-2xl bg-card/60 backdrop-blur-lg p-4 border border-border/40 dark:border-[#4C8CE4]/10 flex-col gap-4 overflow-hidden relative shadow-sm">
      <div className="flex justify-between items-center shrink-0">
        <span className="text-[11px] font-bold uppercase tracking-wider text-foreground flex items-center gap-1.5">
           <BarChart3 className="size-3.5" /> {t("analyticsTitle")}
        </span>
        <span className="text-[9px] font-bold bg-[#91D06C]/10 text-[#91D06C] px-1.5 py-0.5 rounded border border-[#91D06C]/20">
          +40% ROI
        </span>
      </div>

      <div className="flex-1 relative w-full h-[150px] overflow-hidden">
        <AnimatePresence>
          {/* View 1: KPIs */}
          {step === 0 && (
            <motion.div 
              key="kpis"
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 20, position: 'absolute', top: 0, left: 0 }}
              className="grid grid-cols-2 gap-2 z-10 relative w-full h-full"
            >
               <div className="bg-background border border-border/50 p-2.5 rounded-xl shadow-sm flex flex-col justify-center">
                 <span className="text-[9px] text-muted-foreground font-bold block uppercase mb-0.5">{t("kpiGptRevenue")}</span>
                 <div className="text-sm font-black text-foreground">
                   <AnimatedCounter value={9540} prefix="$" />
                 </div>
               </div>
               <div className="bg-background border border-border/50 p-2.5 rounded-xl shadow-sm flex flex-col justify-center">
                 <span className="text-[9px] text-muted-foreground font-bold block uppercase mb-0.5">{t("kpiCopyProfit")}</span>
                 <div className="text-sm font-black text-foreground">
                   <AnimatedCounter value={4250} prefix="$" />
                 </div>
               </div>
               <div className="bg-background border border-border/50 p-2.5 rounded-xl shadow-sm flex flex-col justify-center">
                 <span className="text-[9px] text-muted-foreground font-bold block uppercase mb-0.5">{t("kpiNotionComm")}</span>
                 <div className="text-sm font-black text-foreground">
                   <AnimatedCounter value={3400} prefix="$" />
                 </div>
               </div>
               <div className="bg-background border border-border/50 p-2.5 rounded-xl shadow-sm flex flex-col justify-center">
                 <span className="text-[9px] text-muted-foreground font-bold block uppercase mb-0.5">{t("kpiAvgCpa")}</span>
                 <div className="text-sm font-black text-foreground">
                   <AnimatedCounter value={8} prefix="$" />
                 </div>
               </div>
            </motion.div>
          )}

          {/* View 2: Area Chart */}
          {step === 1 && (
            <motion.div
              key="chart"
              initial={{ opacity: 0, x: -20 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 20, position: 'absolute', top: 0, left: 0 }}
              className="absolute inset-0 flex flex-col justify-end w-full h-full pb-2"
            >
               <span className="text-[10px] highlight-gradient uppercase tracking-widest pl-2 mb-2 block">{t("cvrGrowth")}</span>
               <svg viewBox="0 0 100 40" className="w-full h-24 preserve-3d" preserveAspectRatio="none">
                  <defs>
                    <linearGradient id="gradient" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stopColor="var(--primary)" stopOpacity="0.4" />
                      <stop offset="100%" stopColor="var(--primary)" stopOpacity="0" />
                    </linearGradient>
                  </defs>
                  <motion.path 
                    d="M0,40 L0,30 C20,30 30,10 50,20 C70,30 80,5 100,10 L100,40 Z" 
                    fill="url(#gradient)"
                    initial={{ opacity: 0 }}
                    animate={{ opacity: 1 }}
                    transition={{ duration: 0.8, delay: 0.2 }}
                  />
                  <motion.path 
                    d="M0,30 C20,30 30,10 50,20 C70,30 80,5 100,10" 
                    fill="none"
                    stroke="var(--primary)"
                    strokeWidth="2"
                    initial={{ pathLength: 0 }}
                    animate={{ pathLength: 1 }}
                    transition={{ duration: 1.2, ease: "easeOut" }}
                  />
               </svg>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
};

// ----------------------------------------------------------------------
// 4. Project Management Preview (Live Mockup: Connect Ads & Input Refs)
// ----------------------------------------------------------------------
const ProjectManagementPreview = () => {
  const [step, setStep] = useState(0);
  const t = useTranslations("landing.features.projects.animation");

  useEffect(() => {
    // 0: Init & Focus Left (Nodes sliding in)
    // 1: Connect lines draw out
    // 2: Pan to Right Hub
    // 3: Aggregate Costs roll up
    // 4: Zoom Right Hub & Ref Input pops up
    // 5: Typing Ref
    // 6: Pull back to full landscape view
    const timer = setInterval(() => {
      setStep((prev) => (prev + 1) % 7); 
    }, 2200); 
    return () => clearInterval(timer);
  }, []);

  // Aggregated Cost logic
  const aggregatedCost = step >= 3 ? 4100 : 0;

  // Camera settings
  const getCameraState = (s: number) => {
    switch(s) {
      case 0:
      case 1:
        return { x: 180, y: 0, scale: 1.15 }; // Focused Left
      case 2:
      case 3:
        return { x: -180, y: 0, scale: 1.05 }; // Focused Right
      case 4:
      case 5:
        return { x: -180, y: -20, scale: 1.1 }; // Slight push in for input
      case 6:
        // Full pull-back to show perfect diagram
        return { x: -20, y: 0, scale: 0.7 }; 
      default:
        return { x: -20, y: 0, scale: 0.7 };
    }
  };

  const camera = getCameraState(step);

  return (
    <div className="flex flex-1 w-full h-[220px] lg:h-[280px] rounded-2xl bg-card/60 backdrop-blur-lg border border-border/40 relative overflow-hidden items-center justify-center shadow-sm font-sans text-foreground">
        
        {/* Floating Action Overlay indicating manual operation */}
        <AnimatePresence>
           {step === 5 && (
              <motion.div 
                 initial={{ opacity: 0, scale: 0.5, y: -10 }} animate={{ opacity: 1, scale: 1, y: 0 }} exit={{ opacity: 0, scale: 0.8 }}
                 className="absolute top-4 bg-foreground text-background px-4 py-2 rounded-full text-[10px] font-bold z-30 shadow-2xl flex items-center gap-2 uppercase tracking-widest border border-foreground/20"
              >
                 <CheckCircle2 className="size-3.5" />
                 {t("manualSyncOverlay", { fallback: "Manual Sync" })}
              </motion.div>
           )}
        </AnimatePresence>

        {/* The Cinematic World Canvas (Fixed Absolute Size to prevent any stretching!) */}
        <motion.div 
           animate={{ x: camera.x, y: camera.y, scale: camera.scale }}
           transition={{ duration: 1.2, ease: [0.25, 0.1, 0.25, 1] }}
           className="w-[660px] h-[300px] absolute flex items-center justify-center transform-origin-center"
        >
            {/* SVG Data Pipeline Connections (Fixed Coordinates) */}
            <svg className="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 660 300">
               <defs>
                 <linearGradient id="gradientFlowProject" x1="0" y1="0" x2="1" y2="0">
                   <stop offset="0%" stopColor="currentColor" stopOpacity="0.05" />
                   <stop offset="50%" stopColor="currentColor" stopOpacity="0.8" />
                   <stop offset="100%" stopColor="currentColor" stopOpacity="1" />
                 </linearGradient>
                 <filter id="glowProject">
                    <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                    <feMerge>
                        <feMergeNode in="coloredBlur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                 </filter>
               </defs>

               {/* 
                 Left Nodes edge: X = 180
                 Right Hub Left edge: X = 420
                 Y targets: Top=90, Mid=150, Bot=210
               */}

               {/* Base Dashed Paths from X=210 (Node edge) to X=420 (Hub Edge) */}
               <path d="M 210 65 C 315 65, 315 150, 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />
               <path d="M 210 150 L 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />
               <path d="M 210 235 C 315 235, 315 150, 420 150" fill="none" stroke="currentColor" strokeOpacity="0.15" strokeWidth="2" strokeDasharray="4 4" />

               {/* Animated Solid Paths */}
               <motion.path 
                  d="M 210 65 C 315 65, 315 150, 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut" }}
               />
               <motion.path 
                  d="M 210 150 L 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut", delay: 0.15 }}
               />
               <motion.path 
                  d="M 210 235 C 315 235, 315 150, 420 150" fill="none" stroke="url(#gradientFlowProject)" strokeWidth="2"
                  initial={{ pathLength: 0, opacity: 0 }}
                  animate={{ pathLength: step >= 1 ? 1 : 0, opacity: step >= 1 ? 1 : 0 }}
                  transition={{ duration: 1.2, ease: "easeInOut", delay: 0.3 }}
               />

               {/* Data Pulses moving along exact paths */}
               {(step >= 2 && step <= 5) && (
                 <>
                   <motion.circle r="3.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2s" repeatCount="indefinite" path="M 210 65 C 315 65, 315 150, 420 150" />
                   </motion.circle>
                   <motion.circle r="4" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="1.7s" repeatCount="indefinite" begin="0.3s" path="M 210 150 L 420 150" />
                   </motion.circle>
                   <motion.circle r="3.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2.1s" repeatCount="indefinite" begin="0.6s" path="M 210 235 C 315 235, 315 150, 420 150" />
                   </motion.circle>
                   {/* Second wave */}
                   <motion.circle r="2.5" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="2s" repeatCount="indefinite" begin="1s" path="M 210 65 C 315 65, 315 150, 420 150" />
                   </motion.circle>
                   <motion.circle r="3" fill="currentColor" filter="url(#glowProject)">
                     <animateMotion dur="1.7s" repeatCount="indefinite" begin="1.2s" path="M 210 150 L 420 150" />
                   </motion.circle>
                 </>
               )}
            </svg>

            {/* left column Nodes (Hierarchical Data Path) */}
            {/* Right Edge must remain at X = 210. Width 180 -> Left = 30 */}
            <div className="absolute left-[30px] top-[27.5px] flex flex-col gap-2.5 z-10 w-[180px]">
                
                {/* Node 1 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">farm1@gmail.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 341-992-120</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Scale_Max_US</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Search_Exact</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: RSVP_Alpha</span></div>
                       
                       {/* Connection nub */}
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>

                {/* Node 2 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }} transition={{ delay: 0.15 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">agency4@outlook.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 512-108-410</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Promo_Retarget</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Broad_Match</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: Sale_Offer</span></div>
                       
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>

                {/* Node 3 */}
                <AnimatePresence>
                   <motion.div 
                     initial={{ opacity: 0, x: -30, scale: 0.9 }} animate={{ opacity: 1, x: 0, scale: 1 }} transition={{ delay: 0.3 }}
                     className="bg-card/90 text-foreground backdrop-blur-md border border-border/80 rounded-xl p-2.5 h-[75px] flex flex-col justify-between shadow-lg w-full relative overflow-hidden"
                   >
                       <div className="flex items-center gap-1.5"><Mail className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">buy_vps2@yahoo.com</span></div>
                       <div className="flex items-center gap-1.5 ml-2"><Briefcase className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Acc: 901-443-551</span></div>
                       <div className="flex items-center gap-1.5 ml-4"><Folder className="size-2.5 text-muted-foreground"/><span className="text-[8px] font-medium text-muted-foreground truncate">Cmp: Brand_Defense</span></div>
                       <div className="flex items-center gap-1.5 ml-6"><Layers className="size-2.5 text-[#4C8CE4]/80"/><span className="text-[8px] font-bold text-foreground truncate">Grp: Phrase_KW</span></div>
                       <div className="flex items-center gap-1.5 ml-8"><FileText className="size-2.5 text-[#4C8CE4]"/><span className="text-[9px] font-black text-[#4C8CE4] truncate">Ad: Core_Value</span></div>
                       
                       <div className="absolute right-[-4px] top-1/2 -translate-y-1/2 size-2 rounded-full bg-border" />
                   </motion.div>
                </AnimatePresence>
            </div>

            {/* Project Hub Stack (Background Cards to imply multiple projects) */}
            <div className="absolute left-[432px] top-[40px] w-[230px] h-[200px] bg-card/40 border border-border/40 rounded-2xl z-10 scale-[0.96] shadow-sm backdrop-blur-[2px]" />
            <div className="absolute left-[442px] top-[30px] w-[230px] h-[200px] bg-card/20 border border-border/20 rounded-2xl z-0 scale-[0.92] backdrop-blur-[4px]" />

            {/* Right Dashboard Node (Fixed absolute position) */}
            {/* Center X = 535 (Width 230 so Edges 420 to 650) */}
            <div className="absolute left-[420px] top-[50px] w-[230px] h-[200px] bg-card/95 backdrop-blur-md border border-border/80 rounded-2xl p-5 flex flex-col justify-between shadow-xl z-20 overflow-hidden shrink-0">
                
                {/* Connection nub receiver */}
                <div className="absolute left-[-4px] top-[100px] -translate-y-1/2 size-2 rounded-full bg-border" />
                {/* Subtle gradient flash when data arrives */}
                <motion.div 
                    animate={{ opacity: (step >= 2 && step <= 4) ? [0, 0.3, 0] : 0 }} 
                    transition={{ repeat: Infinity, duration: 2 }} 
                    className="absolute inset-0 bg-gradient-to-r from-foreground/10 to-transparent pointer-events-none" 
                />

                <div className="flex flex-col gap-1 relative z-10 p-0.5">
                    <div className="flex items-center gap-2 text-muted-foreground mb-1.5">
                        <FolderKanban className="size-4" />
                        <span className="text-[10px] font-black uppercase tracking-widest truncate">{t("project")}</span>
                    </div>
                    <span className="text-[11px] font-bold text-muted-foreground uppercase pt-1">{t("totalSpend")}</span>
                    <span className="text-3xl font-black text-foreground tabular-nums tracking-tight leading-none mb-1">
                        $<AnimatedCounter value={aggregatedCost} />
                    </span>
                </div>

                <div className="w-full relative min-h-[75px] mt-auto flex items-end">
                    <AnimatePresence mode="popLayout">
                        {step <= 3 && (
                            <motion.div 
                                key="connecting"
                                initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0, y: 15 }}
                                className="w-full flex justify-center items-center h-[75px] text-[11px] text-muted-foreground font-medium italic"
                            >
                                {step === 0 ? t("connectAdsTitle") : (step <= 2 ? t("syncingAccounts") : t("accountsConnected"))}
                            </motion.div>
                        )}
                        
                        {(step === 4 || step === 5) && (
                            <motion.div 
                                key="input"
                                initial={{ opacity: 0, y: 30 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, scale: 0.95 }}
                                className="w-full bg-background border border-border/80 rounded-xl p-3 shadow-inner h-[75px] flex flex-col justify-center"
                            >
                                <span className="text-[10px] font-bold text-foreground block mb-2">{t("inputRefTitle")}</span>
                                <div className="h-8 w-full bg-muted/40 rounded-lg flex items-center px-2.5 border border-border/50 text-[12px] font-semibold text-foreground relative">
                                    <span className="text-muted-foreground mr-2">{t("refValueLabel", { fallback: "Ref:" })}</span>
                                    <span className="opacity-0">452</span>
                                    <div className="absolute left-[40px] overflow-hidden">
                                        <motion.div 
                                            initial={{ width: 0 }} animate={{ width: step === 5 ? "auto" : 0 }}
                                            className="tabular-nums font-bold"
                                        >
                                            452
                                        </motion.div>
                                    </div>
                                    {step === 4 && <motion.div animate={{ opacity:[0,1,0] }} transition={{ repeat: Infinity }} className="h-4 w-[2px] bg-foreground ml-1" />}
                                </div>
                            </motion.div>
                        )}

                        {step >= 6 && (
                            <motion.div 
                                key="results"
                                initial={{ opacity: 0, y: 30, scale: 0.9 }} animate={{ opacity: 1, y: 0, scale: 1 }}
                                className="w-full flex items-end gap-2.5 h-[75px]"
                            >
                                <div className="flex-1 bg-[#91D06C]/10 border border-[#91D06C]/30 rounded-xl p-2.5 flex flex-col justify-center h-full relative overflow-hidden text-center shadow-sm">
                                    <span className="text-[9px] font-bold text-[#91D06C] uppercase tracking-wider mb-1">{t("trueCpa")}</span>
                                    <span className="text-[18px] font-black text-[#91D06C] tracking-tight leading-none">$9.07</span>
                                </div>
                                <div className="w-[70px] bg-background border border-border/60 rounded-xl p-2.5 flex flex-col justify-center h-full text-center shadow-sm">
                                    <span className="text-[9px] font-bold text-muted-foreground uppercase tracking-wider mb-1">{t("roi")}</span>
                                    <span className="text-[14px] font-black text-foreground tracking-tight leading-none">312%</span>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>
                </div>
            </div>

        </motion.div>
    </div>
  );
};
