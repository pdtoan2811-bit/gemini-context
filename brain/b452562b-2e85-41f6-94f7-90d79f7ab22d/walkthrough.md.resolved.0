/**
 * Types for the enhanced Project ↔ Campaign ↔ Link Ref mapping model.
 * Used exclusively in the sandbox/prototype environment.
 */

/* ───────────────────── Status enums ───────────────────── */

export type ProjectStatus = "running" | "saved" | "archived";

export type CampaignStatus =
  | "enabled"
  | "paused"
  | "removed"
  | "archived"
  | "pending_review";

export type LinkRefStatus = "active" | "inactive";

export type SyncEventType =
  | "project_created"
  | "campaign_connected"
  | "campaign_disconnected"
  | "campaign_migrated"
  | "linkref_created"
  | "linkref_edited"
  | "linkref_dedup"
  | "url_changed_external"
  | "campaign_paused_external"
  | "campaign_removed_external"
  | "sync_completed"
  | "sync_error"
  | "api_rate_limit"
  | "validation_error"
  | "two_way_sync_triggered";

/* ───────────────────── Core entities ───────────────────── */

export interface SandboxProject {
  id: string;
  name: string;
  status: ProjectStatus;
  description?: string;
  url?: string;
  createdAt: string;
  updatedAt: string;
  /** IDs of link refs belonging to this project */
  linkRefIds: string[];
  /** IDs of campaigns currently mapped to this project */
  campaignIds: string[];
  /** Aggregate metrics */
  totalSpend: number;
  totalClicks: number;
  totalImpressions: number;
  totalConversions: number;
}

export interface RefCountEntry {
  date: string; // YYYY-MM-DD
  count: number;
}

export interface LinkRef {
  id: string;
  /** The unique URL (landing page) — unique per user account */
  url: string;
  /** Project this link ref belongs to */
  projectId: string;
  status: LinkRefStatus;
  createdAt: string;
  /** IDs of campaigns mapped to this link ref */
  campaignIds: string[];
  /** Aggregate metrics inherited from mapped campaigns */
  totalClicks: number;
  totalConversions: number;
  /** Daily ref counts (manually entered or bulk imported) */
  refCounts: RefCountEntry[];
}

export interface AdsCampaign {
  id: string;
  /** Google Ads campaign name */
  name: string;
  /** Google Ads account name */
  accountName: string;
  /** Google Ads account ID */
  accountId: string;
  /** Owner email */
  ownerEmail: string;
  /** Landing page / Final URL on Google Ads */
  finalUrl: string;
  status: CampaignStatus;
  /** Link ref this campaign is mapped to (null if unmapped) */
  linkRefId: string | null;
  /** Project this campaign belongs to (null if unmapped) */
  projectId: string | null;
  /** Campaign type */
  campaignType: "search" | "display" | "video" | "shopping" | "pmax";
  /** Currency code */
  currencyCode: string;
  /** Daily budget */
  dailyBudget: number;
  /** Metrics */
  cost: number;
  clicks: number;
  impressions: number;
  conversions: number;
  cpc: number;
  ctr: number;
  startDate: string;
  updatedAt: string;
}

export interface SyncEvent {
  id: string;
  type: SyncEventType;
  timestamp: string;
  /** Human-readable description */
  message: string;
  /** Related entity IDs */
  projectId?: string;
  campaignId?: string;
  linkRefId?: string;
  /** Extra metadata */
  meta?: Record<string, unknown>;
}

/** Time-windowed junction: tracks when each campaign was connected/disconnected from a project */
export interface CampaignConnection {
  id: string;
  campaignId: string;
  projectId: string;
  linkRefId: string;
  /** When user clicked "Sync" to connect */
  connectedAt: string;
  /** When disconnected — null = currently active */
  disconnectedAt: string | null;
}

/* ───────────────────── Store state ───────────────────── */

export interface ProjectCampaignState {
  projects: SandboxProject[];
  linkRefs: LinkRef[];
  campaigns: AdsCampaign[];
  /** Time-windowed connection ledger — source of truth for historical queries */
  connections: CampaignConnection[];
  events: SyncEvent[];
  /** Currently active scenario ID (null = default state) */
  activeScenario: ScenarioId | null;
  /** Whether a sync/animation is in progress */
  isSyncing: boolean;
  /** Current sync step label for animation */
  syncStep: string | null;
}

/* ───────────────────── Scenarios ───────────────────── */

export type ScenarioId =
  | "create_empty_project"
  | "connect_sync_campaigns"
  | "auto_linkref_new"
  | "auto_linkref_dedup"
  | "case_3a_url_changed"
  | "case_3b_edit_linkref"
  | "case_3c_bait_link"
  | "disconnect_campaign"
  | "campaign_removed_external"
  | "error_duplicate_linkref"
  | "error_api_rate_limit"
  | "error_no_landing_page";

export interface ScenarioConfig {
  id: ScenarioId;
  title: string;
  description: string;
  category: "create" | "update" | "delete" | "error";
  /** The category label displayed in the badge */
  categoryLabel: string;
}

/* ───────────────────── Action types ───────────────────── */

export type ProjectCampaignAction =
  | { type: "LOAD_SCENARIO"; scenario: ScenarioId }
  | { type: "RESET" }
  | { type: "SET_SYNCING"; isSyncing: boolean; syncStep?: string | null }
  | { type: "CREATE_PROJECT"; project: SandboxProject }
  | {
      type: "CONNECT_CAMPAIGNS";
      projectId: string;
      campaignIds: string[];
    }
  | {
      type: "DISCONNECT_CAMPAIGN";
      campaignId: string;
    }
  | {
      type: "MIGRATE_CAMPAIGN";
      campaignId: string;
      toProjectId: string;
      newFinalUrl: string;
    }
  | {
      type: "EDIT_LINKREF";
      linkRefId: string;
      newUrl: string;
    }
  | {
      type: "CAMPAIGN_URL_CHANGED_EXTERNAL";
      campaignId: string;
      newUrl: string;
    }
  | {
      type: "CAMPAIGN_STATUS_CHANGED_EXTERNAL";
      campaignId: string;
      newStatus: CampaignStatus;
    }
  | {
      type: "ADD_EVENT";
      event: SyncEvent;
    }
  | {
      type: "SET_STATE";
      state: Partial<ProjectCampaignState>;
    }
  | {
      type: "ADD_LINKREF";
      projectId: string;
      url: string;
    }
  | {
      type: "ADD_REF_COUNTS";
      linkRefId: string;
      entries: RefCountEntry[];
    };
