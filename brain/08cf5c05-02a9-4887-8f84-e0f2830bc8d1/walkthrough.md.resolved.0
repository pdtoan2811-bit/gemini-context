        <div className="flex items-center gap-2.5">
          <div className="relative">
            <div className="size-7 bg-[#4C8CE4]/10 rounded-xl flex items-center justify-center shadow-sm border border-[#4C8CE4]/20">
              <Sparkles className="size-4 text-[#4C8CE4]" />
            </div>
            <div className="absolute -bottom-0.5 -right-0.5 size-3 bg-[#91D06C] border-[2px] border-background rounded-full shadow-sm" />
          </div>
          <span className="text-sm highlight-gradient">Adecos AI</span>
        </div>
      </div>

      {/* Chat Body */}
      <div className="flex-1 p-4 md:p-5 flex flex-col gap-5 relative z-10 justify-start overflow-hidden w-full">
